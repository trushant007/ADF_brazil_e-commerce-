{
	"name": "err_var_to_ADLS",
	"properties": {
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "dummy_json",
						"type": "DatasetReference"
					},
					"name": "source1"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "err_date_actual_file",
						"type": "DatasetReference"
					},
					"name": "sink1"
				}
			],
			"transformations": [
				{
					"name": "parse1"
				},
				{
					"name": "flatten1"
				},
				{
					"name": "derivedColumn1"
				}
			],
			"scriptLines": [
				"parameters{",
				"     p_failed_dates as string",
				"}",
				"source(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false,",
				"     rowUrlColumn: 'filename_anchor',",
				"     documentForm: 'documentPerLine') ~> source1",
				"derivedColumn1 parse(parsed_errors = input_string ? (order_date as string)[],",
				"     format: 'json',",
				"     documentForm: 'singleDocument') ~> parse1",
				"parse1 foldDown(unroll(parsed_errors, parsed_errors),",
				"     mapColumn(",
				"          order_date = parsed_errors.order_date",
				"     ),",
				"     skipDuplicateMapInputs: false,",
				"     skipDuplicateMapOutputs: false) ~> flatten1",
				"source1 derive(input_string = toString(fromBase64($p_failed_dates))) ~> derivedColumn1",
				"flatten1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     umask: 0466,",
				"     preCommands: [],",
				"     postCommands: [],",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> sink1"
			]
		}
	}
}